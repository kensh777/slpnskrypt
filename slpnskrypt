-- HWID gracza
local hwid = tostring(game:GetService("RbxAnalyticsService"):GetClientId())

-- ========================
-- Base64 dekoder
-- ========================
local b64chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
local function b64decode(data)
    data = data:gsub("[^" .. b64chars .. "=]", "")
    local result = {}
    local i = 1
    while i <= #data do
        local c1 = b64chars:find(data:sub(i,i), 1, true) or 65
        local c2 = b64chars:find(data:sub(i+1,i+1), 1, true) or 65
        local c3 = b64chars:find(data:sub(i+2,i+2), 1, true) or 65
        local c4 = b64chars:find(data:sub(i+3,i+3), 1, true) or 65
        c1 = c1 - 1; c2 = c2 - 1; c3 = c3 - 1; c4 = c4 - 1
        local n = c1 * 262144 + c2 * 4096 + c3 * 64 + c4
        table.insert(result, string.char(math.floor(n / 65536)))
        if data:sub(i+2,i+2) ~= "=" then
            table.insert(result, string.char(math.floor(n / 256) % 256))
        end
        if data:sub(i+3,i+3) ~= "=" then
            table.insert(result, string.char(n % 256))
        end
        i = i + 4
    end
    return table.concat(result)
end

-- ========================
-- XOR deszyfrowanie
-- ========================
local function xorDecrypt(b64data, key)
    local decoded = b64decode(b64data)
    local result = {}
    for i = 1, #decoded do
        local b1 = string.byte(decoded, i)
        local b2 = string.byte(key, ((i - 1) % #key) + 1)
        result[i] = string.char(bit32.bxor(b1, b2))
    end
    return table.concat(result)
end

-- ========================
-- KROK 1: Pobierz token
-- ========================
local ok1, authRaw = pcall(function()
    return game:HttpGet(BASE_URL .. "/auth?hwid=" .. hwid)
end)

if not ok1 or not authRaw or authRaw == "" then
    error("[Loader] Blad polaczenia z serwerem.")
end

local token = authRaw:match('"token":"([^"]+)"')
local sig   = authRaw:match('"sig":"([^"]+)"')

if not token or not sig then
    local errMsg = authRaw:match('"error":"([^"]+)"') or "Brak dostepu"
    error("[Loader] " .. errMsg)
end

-- ========================
-- KROK 2: Pobierz zaszyfrowany skrypt
-- ========================
local url = BASE_URL .. "/getscript?hwid=" .. hwid .. "&token=" .. token .. "&sig=" .. sig

local ok2, payload = pcall(function()
    return game:HttpGet(url)
end)

if not ok2 or not payload or payload == "" then
    error("[Loader] Nie mozna pobrac skryptu.")
end

-- ========================
-- KROK 3: Deszyfruj
-- ========================
-- Payload format: encryptedKey|encryptedScript
local sep = payload:find("|", 1, true)
if not sep then
    error("[Loader] Nieprawidlowy format danych.")
end

local encKey    = payload:sub(1, sep - 1)
local encScript = payload:sub(sep + 1)

-- Odzyskaj klucz skryptu
local scriptKey = xorDecrypt(encKey, LOCAL_PART)

-- Odzszyfruj skrypt
local finalScript = xorDecrypt(encScript, scriptKey)

-- ========================
-- KROK 4: Uruchom skrypt
-- ========================
local fn, loadErr = loadstring(finalScript)
if not fn then
    error("[Loader] Blad parsowania skryptu: " .. tostring(loadErr))
end

fn()
